<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:padding="16dp">

    <!-- Top Header: Date & Time -->
    <RelativeLayout
        android:id="@+id/header_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true">
        
        <TextView
            android:id="@+id/widget_date_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:text="السبت، ٢٥ رمضان"
            android:textColor="#A0AEC0"
            android:textSize="11sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Center: Quran Verse -->
    <LinearLayout
        android:id="@+id/verse_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/header_row"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:orientation="vertical">
        
        <TextView
            android:id="@+id/widget_quran_verse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="﴿ وَمَا تُقَدِّمُوا لِأَنفُسِكُم مِّنْ خَيْرٍ تَجِدُوهُ عِندَ اللَّهِ ﴾"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:ellipsize="end"
            android:maxLines="3"
            android:fontFamily="serif" />
            
        <TextView
            android:id="@+id/widget_quran_ref"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="سورة المزمل • ٢٠"
            android:textColor="#384E36"
            android:textSize="10sp"
            android:layout_marginTop="2dp"
            android:textStyle="italic" />
    </LinearLayout>

    <!-- Progress Stats -->
    <RelativeLayout
        android:id="@+id/stats_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/verse_container"
        android:layout_marginTop="12dp">
        
        <TextView
            android:id="@+id/widget_level"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:text="مستوى 1"
            android:textColor="#FBBF24"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_streak_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="🔥 0"
            android:textColor="#F87171"
            android:textSize="10sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Task Progress -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/stats_row"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView android:id="@+id/task_listen" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🎧" android:textSize="14sp" android:layout_marginEnd="8dp"/>
        <TextView android:id="@+id/task_read" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📖" android:textSize="14sp" android:layout_marginEnd="8dp"/>
        <TextView android:id="@+id/task_write" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="✍️" android:textSize="14sp" android:layout_marginEnd="8dp"/>
        <TextView android:id="@+id/task_memorize" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🧠" android:textSize="14sp" android:layout_marginEnd="8dp"/>
        <TextView android:id="@+id/task_quiz" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="❓" android:textSize="14sp" />

    </LinearLayout>

</RelativeLayout>
